# PostgreSQL connection (Prisma CLI + runtime adapter). Used by prisma.config.ts and src/lib/prisma.ts.
# Local Postgres example — same DB name as in docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rounds_monitor"

# HTTP port for Express (src/server.ts). Default 3000.
PORT=3000

# Optional: path to Chromium when not using Puppeteer's bundled browser (e.g. Docker image sets this in Dockerfile).
# PUPPETEER_EXECUTABLE_PATH=
