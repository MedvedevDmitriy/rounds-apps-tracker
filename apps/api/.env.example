# HTTP port (Express).
PORT=3000

# Postgres for Prisma (local default matches docker-compose: db rounds_monitor on :5432).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rounds_monitor

# In-process screenshot scheduler: only the string "true" enables it.
ENABLE_SCREENSHOT_WORKER=false

# Milliseconds between full cycles over all apps.
WORKER_SCREENSHOT_INTERVAL_MS=1800000

# Chromium binary path; empty = Puppeteer default (Dockerfile sets this in containers).
PUPPETEER_EXECUTABLE_PATH=

# Play Store page viewport (px).
SCREENSHOT_VIEWPORT_WIDTH=1440
SCREENSHOT_VIEWPORT_HEIGHT=1200

# Listing language (hl) / country (gl) and Accept-Language for stabler captures.
SCREENSHOT_PLAY_STORE_HL=en
SCREENSHOT_PLAY_STORE_GL=US
SCREENSHOT_ACCEPT_LANGUAGE=en-US,en;q=0.9
